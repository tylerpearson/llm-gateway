        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT toStartOfDay(ts) AS time, team_id, sum(cost_usd) AS cost FROM request_logs WHERE $__timeFilter(ts) GROUP BY time, team_id ORDER BY time, team_id",
          "format": 0,
          "queryType": "sql",
          "refId": "A"
        }
      ],
      "title": "Team Spend Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "total_cost_usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "displayName", "value": "Total Cost (USD)" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "requests" },
            "properties": [
              { "id": "displayName", "value": "Requests" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total_input_tokens" },
            "properties": [
              { "id": "displayName", "value": "Input Tokens" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total_output_tokens" },
            "properties": [
              { "id": "displayName", "value": "Output Tokens" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "team_id" },
            "properties": [
              { "id": "displayName", "value": "Team" }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Total Cost (USD)" }]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
          "rawSql": "SELECT team_id, count() AS requests, sum(cost_usd) AS total_cost_usd, sum(input_tokens) AS total_input_tokens, sum(output_tokens) AS total_output_tokens FROM request_logs WHERE $__timeFilter(ts) GROUP BY team_id ORDER BY total_cost_usd DESC",
          "format": 1,
          "queryType": "sql",
          "refId": "A"
        }
      ],
      "title": "Team Summary (selected range)",
      "type": "table"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": {
